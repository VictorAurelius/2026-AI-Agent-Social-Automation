    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const message = $input.first().json;\nconst text = message.message?.text || '';\nconst chatId = message.message?.chat?.id || '';\n\nconst parts = text.trim().split(/\\s+/);\nconst command = (parts[0] || '').toLowerCase().replace('/', '');\nconst args = parts.slice(1).join(' ');\n\n// Parse command with ID (e.g., /approve 15, /view 15)\nconst idMatch = args.match(/^(\\d+)/);\nconst contentId = idMatch ? parseInt(idMatch[1]) : null;\nconst extraArgs = idMatch ? args.replace(/^\\d+\\s*/, '') : args;\n\nreturn [{\n  json: {\n    command,\n    args,\n    contentId,\n    extraArgs,\n    chatId: String(chatId),\n    rawMessage: text\n  }\n}];"
      },
      "id": "extract-command",
      "name": "Extract Command",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 400]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            {"outputKey": "help", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "help", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "status", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "status", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "pending", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "pending", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "view", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "view", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "approve", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "approve", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "reject", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "reject", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "generate", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "generate", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "topics", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "topics", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "health", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "health", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "addtopic", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "addtopic", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "published", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "published", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "suggest", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "suggest", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "suggest_ideas", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "suggest_ideas", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "post_fb", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "post_fb", "operator": {"type": "string", "operation": "equals"}}]}},
            {"outputKey": "post_linkedin", "conditions": {"conditions": [{"leftValue": "={{ $json.command }}", "rightValue": "post_linkedin", "operator": {"type": "string", "operation": "equals"}}]}}
          ],
