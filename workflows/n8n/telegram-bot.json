      "credentials": {"postgres": {"id": "1", "name": "PostgreSQL - Agent Personal"}}
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first().json;\nlet msg;\n\nif (!item || !item.id) {\n  msg = '\u274c Kh\u00f4ng t\u00ecm th\u1ea5y b\u00e0i vi\u1ebft. D\u00f9ng: /view <id>';\n} else {\n  msg = `\ud83d\udcc4 *Content #${item.id}*\\n\\n`;\n  msg += `*Title:* ${item.title}\\n`;\n  msg += `*Platform:* ${item.platform}\\n`;\n  msg += `*Pillar:* ${item.pillar}\\n`;\n  msg += `*Status:* ${item.status}\\n`;\n  msg += `*Created:* ${item.created}\\n\\n`;\n  msg += `---\\n\\n`;\n  \n  // Telegram has 4096 char limit\n  const content = item.generated_content || 'Kh\u00f4ng c\u00f3 n\u1ed9i dung';\n  if (content.length > 3000) {\n    msg += content.substring(0, 3000) + '\\n\\n_(N\u1ed9i dung b\u1ecb c\u1eaft do gi\u1edbi h\u1ea1n Telegram)_';\n  } else {\n    msg += content;\n  }\n  \n  msg += `\\n\\n---\\n`;\n  if (item.status === 'pending_review') {\n    msg += `\u2705 /approve ${item.id} | \u274c /reject ${item.id} <l\u00fd do>`;\n  }\n}\n\nreturn [{ json: { message: msg } }];"
      },
