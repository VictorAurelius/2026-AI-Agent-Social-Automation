    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all().map(i => i.json);\n\nlet msg = '\ud83d\udcdd *B\u00e0i ch\u1edd Review*\\n\\n';\n\nif (items.length === 0) {\n  msg += '\u2705 Kh\u00f4ng c\u00f3 b\u00e0i n\u00e0o ch\u1edd review!';\n} else {\n  items.forEach((item, i) => {\n    msg += `${i+1}. *#${item.id}* ${item.title}\\n`;\n    msg += `   \ud83d\udccc ${item.pillar} | \ud83d\udcc5 ${item.created}\\n\\n`;\n  });\n  msg += `D\u00f9ng /view <id> \u0111\u1ec3 xem n\u1ed9i dung \u0111\u1ea7y \u0111\u1ee7.`;\n}\n\nreturn [{ json: { message: msg } }];"
