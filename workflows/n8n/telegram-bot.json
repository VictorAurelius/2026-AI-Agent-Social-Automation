        "jsCode": "function escapeSql(str) { return str ? str.replace(/'/g, \"''\") : ''; }\n\nconst response = $input.first().json;\nconst promptData = $('Prepare Prompt').first().json;\nconst content = response.message?.content || response.response || 'No content generated';\nconst title = promptData.topic.substring(0, 100);\nconst pillar = promptData.pillar;\n\nconst safeContent = escapeSql(content);\nconst safeTitle = escapeSql(title);\n\nconst query = `INSERT INTO content_queue (title, pillar, platform, generated_content, status, created_at) VALUES ('${safeTitle}', '${pillar}', 'linkedin', '${safeContent}', 'pending_review', NOW()) RETURNING id, title, status`;\n\nreturn [{ json: { query, content, title, pillar } }];"
      },
