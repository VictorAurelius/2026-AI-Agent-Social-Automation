    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const stats = $input.all().map(i => i.json);\nconst counts = {};\nstats.forEach(s => { counts[s.status] = parseInt(s.count); });\n\nlet msg = '\ud83d\udcca *Content Queue Status*\\n\\n';\nmsg += `\u2022 Draft: ${counts.draft || 0}\\n`;\nmsg += `\u2022 \u23f3 Pending Review: ${counts.pending_review || 0}\\n`;\nmsg += `\u2022 \u2705 Approved: ${counts.approved || 0}\\n`;\nmsg += `\u2022 \ud83d\udcc5 Scheduled: ${counts.scheduled || 0}\\n`;\nmsg += `\u2022 \ud83d\ude80 Published: ${counts.published || 0}\\n`;\nmsg += `\u2022 \u274c Rejected: ${counts.rejected || 0}\\n`;\n\nconst total = Object.values(counts).reduce((a, b) => a + b, 0);\nmsg += `\\n\ud83d\udcc8 Total: ${total} b\u00e0i`;\nmsg += `\\n\\nD\u00f9ng /pending \u0111\u1ec3 xem chi ti\u1ebft b\u00e0i ch\u1edd review.`;\n\nreturn [{ json: { message: msg } }];"
      },
      "id": "format-status",
      "name": "Format Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 340]
    },
