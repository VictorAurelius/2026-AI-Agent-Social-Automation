        "jsCode": "const ollamaResult = $('Check Ollama').first().json;\nconst pgResult = $('Check Postgres').first().json;\n\nconst ollamaOk = ollamaResult && ollamaResult.models && !ollamaResult.error;\nconst pgOk = pgResult && pgResult.health === 1 && !pgResult.error;\n\nlet msg = '\ud83d\udd27 *System Health Check*\\n\\n';\nmsg += `\ud83e\udd99 Ollama: ${ollamaOk ? '\u2705 Online' : '\u274c Offline'}\\n`;\nif (ollamaOk && ollamaResult.models) {\n  msg += `   Models: ${ollamaResult.models.map(m => m.name).join(', ')}\\n`;\n}\nmsg += `\ud83d\udc18 PostgreSQL: ${pgOk ? '\u2705 Connected' : '\u274c Disconnected'}\\n`;\nmsg += `\\n\u23f0 Checked at: ${new Date().toISOString()}`;\n\nreturn [{ json: { message: msg } }];"
